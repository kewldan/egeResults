# --- Telegram ---
BOT_TOKEN=123456:PASTE_YOUR_TOKEN_FROM_BOTFATHER
# Кому слать служебные уведомления (новые результаты, новые пользователи) и кого
# пускать в админ-команды (/top, /check). Несколько админов — через запятую.
# Оставьте пустым, чтобы отключить админ-функции.
ADMIN_ID=787751346,1268132424

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ege_notifier

# --- Хранилище FSM бота ---
# Задайте REDIS_URL, чтобы незавершённое добавление ученика переживало рестарт.
# Пусто => MemoryStorage (состояние теряется при перезапуске; ок для разработки).
# REDIS_URL=redis://localhost:6379/0

# --- Источник результатов: mock | ege_spb ---
# ege_spb — реальный сайт; mock — данные из MOCK_FIXTURES_PATH (для разработки).
RESULTS_PROVIDER=ege_spb
MOCK_FIXTURES_PATH=fixtures/results.json
EGE_SPB_BASE_URL=https://www.ege.spb.ru
# Параметры URL: ?mode=...&wave=... (экзаменационная кампания и волна).
EGE_SPB_MODE=ege2026
EGE_SPB_WAVE=1
REQUEST_TIMEOUT=15
REQUEST_DELAY=1.0
# Минимум между ручными проверками одного ученика (кнопка «Обновить»), сек. Лимит
# общий для всех подписчиков: нельзя обновить, если источник опрашивали недавно.
MANUAL_CHECK_COOLDOWN_SECONDS=300

# --- Ссылки-приглашения (шеринг ученика) ---
# Сколько живёт неиспользованная одноразовая ссылка, сек (потом удаляется TTL).
SHARE_LINK_TTL_SECONDS=86400

# --- Картинка с результатами (рендерер render-takumi на Bun + takumi-js) ---
# Из карточки ученика по кнопке «🖼 Картинка для сторис» генерируется PNG с баллами.
# Бот ходит к сервису по HTTP. В docker compose сервис card-renderer поднимается сам,
# а CARD_RENDERER_URL переопределяется на http://card-renderer:3000.
# Локально без Docker: cd render-takumi && bun install && bun run serve.
CARD_RENDERER_ENABLED=true
CARD_RENDERER_URL=http://localhost:3000
CARD_RENDER_SCALE=2
CARD_RENDER_TIMEOUT=30

# --- Монитор страницы-обзора ege.spb.ru ---
# Дешёвый GET одной страницы раз в N секунд. Если вырос счётчик «Количество
# результатов в базе данных» или в #w2 (Основной период) появился новый предмет —
# запускается полная проверка учеников и анонс «результаты выложили» тем, кто без
# паспортных данных. Главный, быстрый триггер.
PAGE_MONITOR_ENABLED=true
PAGE_MONITOR_INTERVAL_SECONDS=300

# --- Расписание проверок (страховка) ---
# Основной триггер — монитор выше; «слепую» периодическую проверку держим редкой
# (по умолчанию раз в 6 часов): ловит смену статуса/апелляции, не двигающие счётчик.
# Если задан CHECK_CRON — используется он, иначе интервал в секундах.
CHECK_INTERVAL_SECONDS=21600
# CHECK_CRON=*/15 8-22 * * *
CHECK_ON_STARTUP=false
TIMEZONE=Europe/Moscow

# --- Безопасность (PII) ---
# Ключ Fernet для шифрования паспортов. Пусто => хранение в открытом виде (только dev).
# Сгенерировать:  uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Секрет для дедупликации учеников (HMAC). Задайте свой и не меняйте после старта.
IDENTITY_SECRET=change-me-please

LOG_LEVEL=INFO
